# ============================================================
# DoNiChannel / livekit_pack
# .gitignore
#
# 提交原则：
# - 提交源码、配置、文档、锁文件
# - 不提交依赖目录、构建产物、可执行文件、缓存、日志、旧版本备份
# - 不提交任何密钥和本地环境配置
# ============================================================


# ============================================================
# 1. 旧版本备份目录
# ============================================================

# 未重构前的旧前端，不再进入版本管理
ui_old/

# 旧版 LiveKit / Python 打包产物目录，不再进入版本管理
livekit_old/

# 其他可能的本地备份目录
backup/
backups/
ui_stable_backup/


# ============================================================
# 2. Node / Vue / Vite 前端依赖与构建产物
# ============================================================

# 依赖目录，非常大，不能提交
node_modules/
ui/node_modules/

# Vite 构建产物
dist/
ui/dist/

# Vite / 包管理器缓存
.vite/
.npm/
.pnpm-store/
.yarn/
.yarn-cache/

# 根目录 package-lock.json 多半是误生成的
# 注意：这只忽略根目录的 package-lock.json，不影响 ui/package-lock.json
/package-lock.json

# 前端锁文件建议提交，确保别人 npm install 版本一致
!ui/package-lock.json


# ============================================================
# 3. Rust / Tauri 编译产物
# ============================================================

# Rust / Tauri 编译目录，非常大
src-tauri/target/

# 额外防御：Tauri 打包输出
src-tauri/bundle/
src-tauri/dist/

# Rust 编译中间产物
*.rlib
*.rmeta
*.pdb

# Cargo.lock 对 Tauri 应用建议提交，不要忽略
!src-tauri/Cargo.lock


# ============================================================
# 4. Python 缓存、虚拟环境、打包产物
# ============================================================

__pycache__/
*.py[cod]
*.pyo

.venv/
venv/
env/

build/
*.egg-info/

# PyInstaller 输出目录通常不提交
dist/

# 如果以后你确实要维护 app.spec，可以删掉这一行
*.spec


# ============================================================
# 5. 可执行文件和二进制产物
# ============================================================

# 不把 exe / dll / msi 放进源码仓库
# 发布安装包请使用 GitHub Releases
*.exe
*.dll
*.msi

# 压缩包通常是临时分发文件，不提交
*.zip
*.7z
*.rar


# ============================================================
# 6. 环境变量、密钥、本地敏感配置
# ============================================================

.env
.env.*
!.env.example

*.pem
*.key
*.crt
*.p12
*.pfx


# ============================================================
# 7. 日志、临时文件、缓存
# ============================================================

*.log
logs/
tmp/
temp/
.cache/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ============================================================
# 8. 编辑器和系统文件
# ============================================================

# 个人 VS Code 配置。团队若要共享配置，可后续单独放白名单。
.vscode/

.idea/

.DS_Store
Thumbs.db
desktop.ini


# ============================================================
# 9. 明确保留的项目文档和工程配置
# ============================================================

# 以下文件/目录建议提交：
# README.md
# PROJECT_GUIDE.md
# docs/
# .editorconfig
# .gitignore


# 后端本地数据库和测试文件
rooms.db
*.db
test_presence.py

# PyInstaller
build/
dist/
*.spec
*.exe